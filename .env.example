# Kopirajte ovaj fajl u .env, ili jednostavno pokrenite "npm start" / "node server.js"
# jednom - .env se automatski generise sa bezbednim, nasumicnim vrednostima
# (vidi scripts/bootstrap-env.js) ako ne postoji.
#
# NIKADA ne komitujte pravi .env fajl na GitHub (vec je u .gitignore).

# 256-bit (64 hex karaktera) kljuc za AES-256-GCM enkripciju osetljivih polja (jmbg, dijagnoza)
ENCRYPTION_KEY=

# Tajni kljuc za potpisivanje JWT tokena (HMAC-SHA256)
JWT_SECRET=

# Port na kome HTTP server slusa
PORT=3000

# Interval automatskog ("redovnog") pravljenja rezervne kopije baze, u minutima
BACKUP_INTERVAL_MINUTES=60
